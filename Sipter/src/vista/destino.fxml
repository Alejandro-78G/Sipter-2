<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controlador.ControladorSeleccionViaje"
            prefWidth="500" prefHeight="400">

    <Label text="Seleccionar Viaje" layoutX="170" layoutY="20"
           style="-fx-font-size:18px; -fx-font-weight:bold;"/>

    <Label text="Lugar de Encuentro:" layoutX="50" layoutY="80"/>
    <ComboBox fx:id="cbLugarEncuentro" layoutX="200" layoutY="75" prefWidth="200"/>

    <Label text="Destino:" layoutX="50" layoutY="130"/>
    <ComboBox fx:id="cbDestino" layoutX="200" layoutY="125" prefWidth="200"/>

    <TableView fx:id="tablaDestinos" layoutX="50" layoutY="180"
               prefWidth="400" prefHeight="160">
        <columns>
            <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="130"/>
            <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="150"/>
            <TableColumn fx:id="colDistancia" text="Distancia (km)" prefWidth="120"/>
        </columns>
    </TableView>

    <Button fx:id="btnSeleccionar" text="Seleccionar" layoutX="200" layoutY="360" prefWidth="100"/>
</AnchorPane>
