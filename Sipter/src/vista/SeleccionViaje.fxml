<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controlador.ControladorSeleccionViaje"
            prefWidth="450" prefHeight="350">

    <VBox alignment="CENTER" spacing="15" layoutX="50" layoutY="30">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Selecciona tu lugar de encuentro" style="-fx-font-size: 14px;"/>
        <ComboBox fx:id="cbLugarEncuentro" prefWidth="250"/>

        <Label text="Selecciona tu destino" style="-fx-font-size: 14px;"/>
        <ComboBox fx:id="cbDestino" prefWidth="250"/>

        <TableView fx:id="tablaDestinos" prefWidth="370" prefHeight="150">
            <columns>
                <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="120"/>
                <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="150"/>
                <TableColumn fx:id="colDistancia" text="Distancia (km)" prefWidth="90"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="btnSeleccionar" text="Guardar selección" onAction="#seleccionarViaje"/>
        </HBox>
    </VBox>

</AnchorPane>
